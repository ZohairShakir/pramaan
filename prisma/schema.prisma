// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(USER)
  
  accounts      Account[]
  sessions      Session[]
  documents     Document[]
  
  organizationName String?
  isVerifiedIssuer Boolean @default(false)
  hasSubmittedProof Boolean @default(false)
  trustScore       Float   @default(0.0)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt
}

enum Role {
  USER
  ISSUER
  ADMIN
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Document {
  id              String   @id @default(cuid())
  userId          String?
  name            String
  hash            String   @unique
  did             String?  @unique
  
  // Blockchain Data
  txHash          String?
  blockNumber     Int?
  network         String   @default("Polygon")
  
  // Metadata
  category        String?  // Education, Hiring, Legal, Healthcare, etc.
  recipientName   String?
  recipientEmail  String?
  metadata        Json?    // For sector-specific data
  
  // Status
  status          DocStatus @default(ACTIVE)
  verifiedAt      DateTime?
  expiresAt       DateTime?
  revokedAt       DateTime?
  
  // Stats
  verificationCount Int    @default(0)
  
  // Relations
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  history         VerificationEvent[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  @@map("documents")
}

enum DocStatus {
  ACTIVE
  REVOKED
  SUSPENDED
}

model VerificationEvent {
  id            String   @id @default(cuid())
  documentId    String
  eventType     String   // ISSUED, VERIFIED, REVOKED, TAMPER_ATTEMPT
  ipAddress     String?
  location      String?
  userAgent     String?
  timestamp     DateTime @default(now())
  
  document      Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("verification_events")
}

model FraudLog {
  id            String   @id @default(cuid())
  hashAttempted String
  ipAddress     String?
  timestamp     DateTime @default(now())
  severity      Int      @default(1) // 1-5
}
